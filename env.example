// ─────────────────────────────────────────────────────────────
//  PERSISTENT STORAGE HOOK
// ─────────────────────────────────────────────────────────────
function useStorage(key, seed) {
  const [data, setData] = useState(() => {
    try {
      const stored = localStorage.getItem("yom_" + key);
      return stored ? JSON.parse(stored) : seed;
    } catch { return seed; }
  });

  const save = useCallback((next) => {
    const val = typeof next === "function" ? next(data) : next;
    setData(val);
    try { localStorage.setItem("yom_" + key, JSON.stringify(val)); } catch {}
  }, [key, data]);

  return [data, save];
}

// ─────────────────────────────────────────────────────────────
//  INLINE EDIT CELL — click to edit
// ─────────────────────────────────────────────────────────────
function EditCell({ value, onSave, type="text", options=null, placeholder="" }) {
  const [editing, setEditing] = useState(false);
  const [val, setVal] = useState(value);
  const ref = useRef();

  useEffect(() => { if (editing && ref.current) ref.current.focus(); }, [editing]);
  useEffect(() => { setVal(value); }, [value]);

  const commit = () => { setEditing(false); if (val !== value) onSave(val); };
  const cancel = () => { setEditing(false); setVal(value); };

  if (!editing) {
    return (
      <div onClick={() => setEditing(true)}
        title="Click to edit"
        style={{cursor:"text",minHeight:22,padding:"1px 4px",borderRadius:4,
          transition:"background 0.1s",display:"inline-flex",alignItems:"center",gap:4,
          ":hover":{background:B.sand}}}
        onMouseEnter={e=>e.currentTarget.style.background=B.sand}
        onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
        {value || <span style={{color:B.textLight,fontStyle:"italic",fontSize:11}}>{placeholder||"—"}</span>}
        <span style={{color:B.border,fontSize:9,opacity:0}}>✏</span>
      </div>
    );
  }

  if (options) {
    return (
      <select ref={ref} value={val}
        onChange={e=>setVal(e.target.value)}
        onBlur={commit}
        onKeyDown={e=>{ if(e.key==="Enter") commit(); if(e.key==="Escape") cancel(); }}
        style={{background:B.white,border:`2px solid ${B.navy}`,borderRadius:5,
          padding:"3px 6px",fontSize:12,color:B.text,outline:"none",
          fontFamily:"inherit",cursor:"pointer",minWidth:140}}>
        {options.map(o=><option key={o} value={o}>{o}</option>)}
      </select>
    );
  }

  if (type === "textarea") {
    return (
      <textarea ref={ref} value={val}
        onChange={e=>setVal(e.target.value)}
        onBlur={commit}
        onKeyDown={e=>{ if(e.key==="Escape") cancel(); }}
        rows={2}
        style={{background:B.white,border:`2px solid ${B.navy}`,borderRadius:5,
          padding:"4px 6px",fontSize:12,color:B.text,outline:"none",
          fontFamily:"inherit",width:"100%",resize:"vertical",minWidth:200}}/>
    );
  }

  return (
    <input ref={ref} type={type} value={val}
      onChange={e=>setVal(e.target.value)}
      onBlur={commit}
      onKeyDown={e=>{ if(e.key==="Enter") commit(); if(e.key==="Escape") cancel(); }}
      style={{background:B.white,border:`2px solid ${B.navy}`,borderRadius:5,
        padding:"3px 6px",fontSize:12,color:B.text,outline:"none",
        fontFamily:"inherit",width: type==="date"?"140px":"120px"}}/>
  );
}

// ─────────────────────────────────────────────────────────────
//  STATUS BADGE (editable)
// ─────────────────────────────────────────────────────────────
function StatusBadge({ value, onSave }) {
  const [open, setOpen] = useState(false);
  const ref = useRef();
  const st = stageOf(value);

  useEffect(() => {
    const handler = e => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, []);

  return (
    <div ref={ref} style={{position:"relative",display:"inline-block"}}>
      <div onClick={() => setOpen(o=>!o)}
        style={{display:"inline-flex",alignItems:"center",gap:5,padding:"4px 10px",
          borderRadius:6,fontSize:11,fontWeight:700,color:st.color,background:st.bg,
          border:`1px solid ${st.color}30`,cursor:"pointer",whiteSpace:"nowrap",
          userSelect:"none"}}>
        <span style={{width:6,height:6,borderRadius:"50%",background:st.dot,flexShrink:0}}/>
        {value||"—"}
        <span style={{fontSize:9,marginLeft:2,opacity:0.6}}>▼</span>
      </div>
      {open && (
        <div style={{position:"absolute",top:"calc(100% + 4px)",left:0,zIndex:200,
          background:B.white,border:`1px solid ${B.border}`,borderRadius:8,
          boxShadow:"0 8px 24px rgba(0,0,0,0.12)",minWidth:200,overflow:"hidden"}}>
          {ALL_STATUSES.map(s => {
            const m = stageOf(s);
            return (
              <div key={s} onClick={() => { onSave(s); setOpen(false); }}
                style={{display:"flex",alignItems:"center",gap:8,padding:"9px 14px",
                  cursor:"pointer",background:s===value?B.sand:B.white,
                  fontSize:12,fontWeight:s===value?700:500,color:m.color,
                  transition:"background 0.1s"}}
                onMouseEnter={e=>e.currentTarget.style.background=B.sand}
                onMouseLeave={e=>e.currentTarget.style.background=s===value?B.sand:B.white}>
                <span style={{width:7,height:7,borderRadius:"50%",background:m.dot,flexShrink:0}}/>
                {s}
                {s===value&&<span style={{marginLeft:"auto",color:B.navy}}>✓</span>}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  TOAST NOTIFICATION
// ─────────────────────────────────────────────────────────────
function Toast({ message, onDone }) {
  useEffect(() => { const t = setTimeout(onDone, 2200); return () => clearTimeout(t); }, [onDone]);
  return (
    <div style={{position:"fixed",bottom:24,right:24,zIndex:999,
      background:B.navy,color:B.white,padding:"11px 18px",borderRadius:10,
      fontSize:13,fontWeight:600,boxShadow:"0 4px 20px rgba(0,0,0,0.2)",
      borderLeft:`3px solid ${B.gold}`,display:"flex",alignItems:"center",gap:8,
      animation:"slideUp 0.25s ease"}}>
      <span style={{color:B.gold}}>✓</span> {message}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  CONFIRM DIALOG
// ─────────────────────────────────────────────────────────────
function Confirm({ message, onConfirm, onCancel }) {
  return (
    <div style={{position:"fixed",inset:0,background:"rgba(27,45,91,0.5)",zIndex:300,
      display:"flex",alignItems:"center",justifyContent:"center"}}>
      <div style={{background:B.white,borderRadius:12,padding:28,maxWidth:360,width:"90%",
        boxShadow:"0 20px 60px rgba(0,0,0,0.2)"}}>
        <div style={{fontSize:15,fontWeight:700,color:B.navy,marginBottom:8}}>Confirm Delete</div>
        <div style={{fontSize:13,color:B.textMid,marginBottom:20,lineHeight:1.5}}>{message}</div>
        <div style={{display:"flex",gap:10,justifyContent:"flex-end"}}>
          <button onClick={onCancel}
            style={{padding:"8px 18px",borderRadius:7,border:`1px solid ${B.border}`,
              background:B.white,color:B.textMid,fontSize:13,cursor:"pointer",fontWeight:600}}>
            Cancel
          </button>
          <button onClick={onConfirm}
            style={{padding:"8px 18px",borderRadius:7,border:"none",
              background:B.red,color:B.white,fontSize:13,cursor:"pointer",fontWeight:700}}>
            Delete
          </button>
        </div>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  TRUCK SCHEDULE
// ─────────────────────────────────────────────────────────────
function TruckSchedule() {
  const [shipments, setShipments] = useStorage("shipments", SEED_SHIPMENTS);
  const [search, setSearch] = useState("");
  const [filter, setFilter] = useState("all");
  const [toast, setToast] = useState(null);
  const [confirmDelete, setConfirmDelete] = useState(null);
  const [expandedId, setExpandedId] = useState(null);

  const toast_ = msg => setToast(msg);

  const updateField = (id, field, val) => {
    setShipments(prev => prev.map(s => s.id===id ? {...s,[field]:val} : s));
    toast_(`Saved`);
  };

  const addRow = () => {
    const newShip = {
      id: uid(), po:"", customer:"", status:"In Progress",
      broker:"", carrier:"", shipDate:"", notes:"",
    };
    setShipments(prev => [newShip, ...prev]);
    setExpandedId(newShip.id);
    toast_("New shipment added — fill in the details");
  };

  const deleteRow = (id) => {
    setShipments(prev => prev.filter(s=>s.id!==id));
    setConfirmDelete(null);
    toast_("Shipment deleted");
  };

  const resetToSeed = () => {
    setShipments(SEED_SHIPMENTS);
    toast_("Reset to original data");
  };

  const filtered = useMemo(() => {
    return shipments.filter(s => {
      const q = search.toLowerCase();
      const matchSearch = !q ||
        (s.po||"").toLowerCase().includes(q) ||
        (s.customer||"").toLowerCase().includes(q) ||
        (s.broker||"").toLowerCase().includes(q) ||
        (s.carrier||"").toLowerCase().includes(q) ||
        (s.status||"").toLowerCase().includes(q);
      if (filter==="all") return matchSearch;
      if (filter==="ready")    return matchSearch && s.status==="Ready to Ship";
      if (filter==="inprogress") return matchSearch && s.status==="In Progress";
      if (filter==="inbound")  return matchSearch && ["From RJW","From Boves","From PCC","Inbound Transfer"].includes(s.status);
      if (filter==="shipped")  return matchSearch && s.status==="PO Shipped";
      return matchSearch;
    });
  }, [shipments, search, filter]);

  const counts = useMemo(()=>({
    all: shipments.length,
    ready: shipments.filter(s=>s.status==="Ready to Ship").length,
    inprogress: shipments.filter(s=>s.status==="In Progress").length,
    inbound: shipments.filter(s=>["From RJW","From Boves","From PCC","Inbound Transfer"].includes(s.status)).length,
    shipped: shipments.filter(s=>s.status==="PO Shipped").length,
  }), [shipments]);

  const editHint = (
    <span style={{fontSize:11,color:B.textLight,fontStyle:"italic"}}>
      ✏ Click any cell to edit · Status badge to change status
    </span>
  );

  return (
    <div style={{display:"flex",flexDirection:"column",gap:14}}>
      {/* Filter pills */}
      <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
        {[
          ["all",    `All (${counts.all})`,       B.navy ],
          ["ready",  `Ready (${counts.ready})`,   B.green],
          ["inprogress",`In Progress (${counts.inprogress})`,B.amber],
          ["inbound",`Inbound (${counts.inbound})`,B.blue],
          ["shipped",`Shipped (${counts.shipped})`,B.textMid],
        ].map(([key,label,color])=>(
          <button key={key} onClick={()=>setFilter(key)}
            style={{background:filter===key?color:B.white,color:filter===key?B.white:color,
              border:`2px solid ${color}`,borderRadius:20,padding:"5px 14px",
              fontSize:12,fontWeight:700,cursor:"pointer",transition:"all 0.15s"}}>
            {label}
          </button>
        ))}
        <input value={search} onChange={e=>setSearch(e.target.value)}
          placeholder="Search…"
          style={{marginLeft:"auto",background:B.white,border:`1.5px solid ${B.border}`,
            borderRadius:20,padding:"6px 14px",fontSize:12,color:B.text,outline:"none",width:200}}/>
        <button onClick={addRow}
          style={{background:B.navy,color:B.white,border:"none",borderRadius:8,
            padding:"7px 16px",fontSize:12,fontWeight:700,cursor:"pointer",
            display:"flex",alignItems:"center",gap:6}}>
          + Add Shipment
        </button>
        <button onClick={resetToSeed}
          style={{background:B.white,color:B.textLight,border:`1px solid ${B.border}`,
            borderRadius:8,padding:"7px 12px",fontSize:11,cursor:"pointer"}}
          title="Reset to original data">
          ↺ Reset
        </button>
      </div>

      {/* Edit hint */}
      <div style={{display:"flex",alignItems:"center",gap:8,padding:"8px 14px",
        background:B.goldFaint,border:`1px solid ${B.gold}40`,borderRadius:8}}>
        <span style={{fontSize:14}}>✏️</span>
        {editHint}
      </div>

      {/* Table */}
      <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
            <thead>
              <tr style={{background:B.navy}}>
                {["PO #","Customer","Ship Date","MABD","Status","Broker","Carrier","Pallets","Notes",""].map(h=>(
                  <th key={h} style={{padding:"11px 12px",textAlign:"left",fontSize:10,
                    fontWeight:700,color:"rgba(255,255,255,0.65)",textTransform:"uppercase",
                    letterSpacing:"0.5px",whiteSpace:"nowrap"}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {filtered.map((s,i)=>{
                const mabd = extractMABD(s.notes);
                const pallets = extractPallets(s.notes);
                const cc = customerColor(s.customer);
                const isExpanded = expandedId === s.id;
                return (
                  <tr key={s.id}
                    style={{background:i%2===0?B.white:B.cream,
                      borderBottom:`1px solid ${B.border}`,
                      verticalAlign:"middle"}}>
                    {/* PO */}
                    <td style={{padding:"10px 12px",fontWeight:700,color:B.navy,minWidth:120}}>
                      <EditCell value={s.po} placeholder="PO #"
                        onSave={v=>updateField(s.id,"po",v)}/>
                    </td>
                    {/* Customer */}
                    <td style={{padding:"10px 12px",minWidth:140}}>
                      <EditCell value={s.customer} placeholder="Customer"
                        onSave={v=>updateField(s.id,"customer",v)}/>
                      {s.customer && (
                        <div style={{marginTop:2}}>
                          <span style={{padding:"1px 6px",borderRadius:3,fontSize:10,
                            fontWeight:700,color:cc.color,background:cc.bg}}>{
                            Object.keys({KEHE:1,UNFI:1,COSTCO:1,Amazon:1,Kroger:1})
                              .find(k=>s.customer?.includes(k))||""
                          }</span>
                        </div>
                      )}
                    </td>
                    {/* Ship Date */}
                    <td style={{padding:"10px 12px",whiteSpace:"nowrap",color:B.textMid}}>
                      <EditCell value={s.shipDate} type="date"
                        onSave={v=>updateField(s.id,"shipDate",v)}/>
                    </td>
                    {/* MABD (extracted from notes — display only) */}
                    <td style={{padding:"10px 12px",whiteSpace:"nowrap"}}>
                      {mabd
                        ? <span style={{fontWeight:700,color:B.red,fontSize:12}}>{mabd}</span>
                        : <span style={{color:B.border}}>—</span>}
                    </td>
                    {/* Status */}
                    <td style={{padding:"10px 12px"}}>
                      <StatusBadge value={s.status}
                        onSave={v=>updateField(s.id,"status",v)}/>
                    </td>
                    {/* Broker */}
                    <td style={{padding:"10px 12px",minWidth:130}}>
                      <EditCell value={s.broker} placeholder="Broker"
                        options={["", ...ALL_BROKERS]}
                        onSave={v=>updateField(s.id,"broker",v)}/>
                    </td>
                    {/* Carrier */}
                    <td style={{padding:"10px 12px",minWidth:110}}>
                      <EditCell value={s.carrier} placeholder="TBD"
                        options={["", ...ALL_CARRIERS]}
                        onSave={v=>updateField(s.id,"carrier",v)}/>
                    </td>
                    {/* Pallets (extracted) */}
                    <td style={{padding:"10px 12px",textAlign:"center",
                      fontWeight:700,color:B.navy}}>
                      {pallets||<span style={{color:B.border}}>—</span>}
                    </td>
                    {/* Notes */}
                    <td style={{padding:"10px 12px",minWidth:180,maxWidth:240}}>
                      <EditCell value={s.notes} placeholder="Notes…" type="textarea"
                        onSave={v=>updateField(s.id,"notes",v)}/>
                    </td>
                    {/* Delete */}
                    <td style={{padding:"10px 8px",textAlign:"center"}}>
                      <button onClick={()=>setConfirmDelete(s)}
                        title="Delete row"
                        style={{background:"none",border:`1px solid ${B.border}`,
                          borderRadius:5,color:B.red,cursor:"pointer",
                          padding:"4px 7px",fontSize:12,lineHeight:1,
                          transition:"all 0.1s"}}
                        onMouseEnter={e=>{e.currentTarget.style.background=B.redFaint;}}
                        onMouseLeave={e=>{e.currentTarget.style.background="none";}}>
                        🗑
                      </button>
                    </td>
                  </tr>
                );
              })}
              {filtered.length===0&&(
                <tr><td colSpan={10} style={{padding:40,textAlign:"center",color:B.textLight}}>
                  No shipments match — <button onClick={()=>{setSearch("");setFilter("all");}}
                    style={{background:"none",border:"none",color:B.navy,cursor:"pointer",
                      fontWeight:700,textDecoration:"underline"}}>clear filter</button>
                </td></tr>
              )}
            </tbody>
          </table>
        </div>
        <div style={{padding:"8px 16px",background:B.cream,borderTop:`1px solid ${B.border}`,
          display:"flex",justifyContent:"space-between",
          fontSize:11,color:B.textLight}}>
          <span>Showing {filtered.length} of {shipments.length} shipments</span>
          <span>All changes auto-saved to browser storage</span>
        </div>
      </div>

      {confirmDelete && (
        <Confirm
          message={`Delete shipment "${confirmDelete.po} / ${confirmDelete.customer}"? This cannot be undone.`}
          onConfirm={()=>deleteRow(confirmDelete.id)}
          onCancel={()=>setConfirmDelete(null)}/>
      )}
      {toast && <Toast message={toast} onDone={()=>setToast(null)}/>}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  INVENTORY (editable)
// ─────────────────────────────────────────────────────────────
function InventoryView() {
  const [inventory, setInventory] = useStorage("inventory", SEED_INVENTORY);
  const [search, setSearch] = useState("");
  const [src, setSrc] = useState("all");
  const [toast, setToast] = useState(null);
  const [confirmDelete, setConfirmDelete] = useState(null);

  const toast_ = msg => setToast(msg);

  const updateItem = (locIdx, itemIdx, field, val) => {
    setInventory(prev => {
      const next = prev.map((loc,li)=>{
        if(li!==locIdx) return loc;
        return {...loc, items: loc.items.map((item,ii)=>
          ii===itemIdx ? {...item,[field]:typeof val==="string"?val:parseInt(val)||0} : item
        )};
      });
      return next;
    });
    toast_("Saved");
  };

  const addItem = (locIdx) => {
    setInventory(prev => prev.map((loc,li)=>li!==locIdx?loc:{
      ...loc,
      items:[...loc.items,{sku:"",desc:"New Item",onHand:0,available:0}]
    }));
    toast_("Row added");
  };

  const deleteItem = (locIdx, itemIdx) => {
    setInventory(prev => prev.map((loc,li)=>li!==locIdx?loc:{
      ...loc, items:loc.items.filter((_,ii)=>ii!==itemIdx)
    }));
    setConfirmDelete(null);
    toast_("Item removed");
  };

  const resetToSeed = () => { setInventory(SEED_INVENTORY); toast_("Reset to original data"); };

  const filtered = useMemo(()=>inventory.filter(loc=>
    src==="all"||(src==="netsuite"&&loc.source==="NetSuite")||(src==="copackers"&&loc.source==="Google Sheet")
  ), [inventory,src]);

  const lowStockItems = inventory.flatMap(l=>l.items.filter(i=>i.onHand<50));

  return (
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      {/* Stats */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12}}>
        {[
          ["Total On-Hand",inventory.flatMap(l=>l.items).reduce((s,i)=>s+i.onHand,0).toLocaleString(),"cases",B.navy],
          ["Locations",inventory.length,"tracked",B.blue],
          ["Low Stock Alerts",lowStockItems.length,"< 50 cases",B.red],
          ["Last Sync","Live","NetSuite + Sheets",B.green],
        ].map(([label,val,sub,accent])=>(
          <div key={label} style={{background:B.white,border:`1px solid ${B.border}`,
            borderLeft:`4px solid ${accent}`,borderRadius:10,padding:"14px 18px"}}>
            <div style={{fontSize:10,fontWeight:700,color:B.textLight,textTransform:"uppercase",
              letterSpacing:"0.5px",marginBottom:6}}>{label}</div>
            <div style={{fontSize:24,fontWeight:900,color:B.navy,lineHeight:1}}>{val}</div>
            <div style={{fontSize:11,color:B.textLight,marginTop:4}}>{sub}</div>
          </div>
        ))}
      </div>

      {/* Controls */}
      <div style={{display:"flex",gap:10,alignItems:"center",flexWrap:"wrap"}}>
        <input value={search} onChange={e=>setSearch(e.target.value)}
          placeholder="Search SKU or description…"
          style={{background:B.white,border:`1.5px solid ${B.border}`,borderRadius:8,
            padding:"7px 14px",fontSize:12,color:B.text,outline:"none",width:220}}/>
        {["all","netsuite","copackers"].map(f=>(
          <button key={f} onClick={()=>setSrc(f)}
            style={{padding:"6px 14px",borderRadius:8,fontSize:12,fontWeight:600,cursor:"pointer",
              border:`1.5px solid ${src===f?B.navy:B.border}`,
              background:src===f?B.navy:B.white,color:src===f?B.white:B.textMid}}>
            {f==="all"?"All":f==="netsuite"?"NetSuite":"Copacker Sheets"}
          </button>
        ))}
        <button onClick={resetToSeed}
          style={{marginLeft:"auto",background:B.white,color:B.textLight,
            border:`1px solid ${B.border}`,borderRadius:8,
            padding:"6px 12px",fontSize:11,cursor:"pointer"}}>
          ↺ Reset
        </button>
      </div>

      <div style={{background:B.goldFaint,border:`1px solid ${B.gold}40`,borderRadius:8,
        padding:"8px 14px",fontSize:11,color:B.textMid}}>
        ✏️ Click any quantity to edit · Use + Add Row to add new SKUs · Changes auto-saved
      </div>

      {/* Location cards */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:14}}>
        {filtered.map((loc,locIdx)=>{
          const isNS = loc.source==="NetSuite";
          const items = search
            ? loc.items.filter(i=>i.sku.includes(search)||i.desc.toLowerCase().includes(search.toLowerCase()))
            : loc.items;
          return (
            <div key={loc.location} style={{background:B.white,border:`1px solid ${B.border}`,
              borderRadius:12,overflow:"hidden"}}>
              <div style={{background:isNS?B.navy:B.navyLight,padding:"12px 16px",
                display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                <div>
                  <div style={{fontSize:13,fontWeight:800,color:B.white}}>{loc.location}</div>
                  <div style={{fontSize:10,color:"rgba(255,255,255,0.55)",marginTop:1}}>
                    {items.length} SKUs · {items.reduce((s,i)=>s+i.onHand,0).toLocaleString()} cases
                  </div>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{padding:"3px 8px",borderRadius:4,fontSize:10,fontWeight:700,
                    color:isNS?B.gold:B.white,background:"rgba(255,255,255,0.15)"}}>
                    {isNS?"NetSuite":"Google Sheet"}
                  </span>
                </div>
              </div>

              {/* Item rows */}
              {items.map((item, itemIdx)=>{
                const realIdx = loc.items.indexOf(item);
                const low = item.onHand < 50;
                const mid = item.onHand < 100;
                return (
                  <div key={itemIdx} style={{
                    padding:"8px 14px",
                    borderBottom:`1px solid ${B.border}`,
                    background:low?"#FFF5F5":B.white,
                    display:"grid",gridTemplateColumns:"60px 1fr 70px 60px 26px",
                    gap:6,alignItems:"center",fontSize:12,
                  }}>
                    {/* SKU */}
                    <EditCell value={item.sku} placeholder="SKU"
                      onSave={v=>updateItem(inventory.indexOf(loc),realIdx,"sku",v)}/>
                    {/* Desc */}
                    <EditCell value={item.desc} placeholder="Description"
                      onSave={v=>updateItem(inventory.indexOf(loc),realIdx,"desc",v)}/>
                    {/* On Hand */}
                    <div style={{textAlign:"right"}}>
                      <div style={{fontSize:14,fontWeight:800,
                        color:low?B.red:mid?B.amber:B.green}}>
                        <EditCell value={String(item.onHand)} type="number" placeholder="0"
                          onSave={v=>updateItem(inventory.indexOf(loc),realIdx,"onHand",v)}/>
                      </div>
                    </div>
                    {/* Available */}
                    <div style={{textAlign:"right",fontSize:10,color:B.textLight}}>
                      <EditCell value={String(item.available)} type="number" placeholder="0"
                        onSave={v=>updateItem(inventory.indexOf(loc),realIdx,"available",v)}/>
                    </div>
                    {/* Delete item */}
                    <button onClick={()=>setConfirmDelete({locIdx:inventory.indexOf(loc),itemIdx:realIdx,label:`${item.sku} at ${loc.location}`})}
                      style={{background:"none",border:"none",color:B.border,cursor:"pointer",
                        fontSize:12,padding:2}}
                      onMouseEnter={e=>e.currentTarget.style.color=B.red}
                      onMouseLeave={e=>e.currentTarget.style.color=B.border}>
                      ✕
                    </button>
                  </div>
                );
              })}

              {/* Add item row */}
              <div style={{padding:"8px 14px",borderTop:`1px solid ${B.border}`,
                background:B.cream}}>
                <button onClick={()=>addItem(inventory.indexOf(loc))}
                  style={{background:"none",border:`1px dashed ${B.borderDark}`,
                    borderRadius:6,padding:"5px 12px",fontSize:11,color:B.textMid,
                    cursor:"pointer",width:"100%",fontFamily:"inherit"}}>
                  + Add SKU row
                </button>
              </div>
            </div>
          );
        })}
      </div>

      {confirmDelete?.label && (
        <Confirm
          message={`Remove "${confirmDelete.label}" from inventory?`}
          onConfirm={()=>deleteItem(confirmDelete.locIdx,confirmDelete.itemIdx)}
          onCancel={()=>setConfirmDelete(null)}/>
      )}
      {toast && <Toast message={toast} onDone={()=>setToast(null)}/>}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  PALLET BUILD PLANNER (with saved plans)
// ─────────────────────────────────────────────────────────────
function buildPlan(skuId, totalCases) {
  const p = PM[skuId];
  if (!p || !totalCases) return null;
  const fullPallets = Math.floor(totalCases / p.casesPerPallet);
  const remainder   = totalCases % p.casesPerPallet;
  const makeLayers  = (cases) => {
    const layers=[]; let rem=cases, n=0;
    while(rem>0){
      n++;
      const c=Math.min(rem,p.ti);
      layers.push({layer:n,cases:c,isPartial:c<p.ti,
        heightAtTop:parseFloat((PALLET_DECK+n*p.caseH).toFixed(2)),
        cumulativeCases:cases-rem+c,
        cumulativeWeight:parseFloat(((cases-rem+c)*p.caseWeight).toFixed(1))});
      rem-=c;
    }
    return layers;
  };
  const pallets=[];
  for(let i=0;i<fullPallets;i++){
    const layers=makeLayers(p.casesPerPallet);
    pallets.push({palletNum:i+1,cases:p.casesPerPallet,layers,full:true,
      totalHeight:parseFloat((PALLET_DECK+p.hi*p.caseH).toFixed(2)),
      totalWeight:parseFloat((p.casesPerPallet*p.caseWeight).toFixed(0))});
  }
  if(remainder>0){
    const layers=makeLayers(remainder);
    pallets.push({palletNum:fullPallets+1,cases:remainder,layers,full:false,
      totalHeight:layers[layers.length-1].heightAtTop,
      totalWeight:parseFloat((remainder*p.caseWeight).toFixed(0))});
  }
  return {product:p,totalCases,pallets,totalPallets:pallets.length};
}

function PalletVisualizer({plan}) {
  if(!plan) return null;
  const p=plan.product;
  const svgH=200, svgW=150;
  const scaleY=(svgH-24)/PALLET_MAX_H;
  const palletW=100, palletX=(svgW-palletW)/2;
  const COLORS=["#1B2D5B","#243570","#C9A84C","#D4B060","#1A7A4A","#22A05F","#C0392B","#2980B9","#8E44AD"];
  const deckH=PALLET_DECK*scaleY;
  const deckY=svgH-18-deckH;
  const pallet=plan.pallets[0];
  if(!pallet) return null;
  return (
    <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:6}}>
      <svg width={svgW} height={svgH} style={{overflow:"visible"}}>
        {[0,20,40,60].map(h=>{
          const y=svgH-18-h*scaleY;
          return <g key={h}>
            <line x1={palletX-6} y1={y} x2={palletX+palletW+6} y2={y}
              stroke={h===60?"#C0392B":"#D8D4C8"} strokeWidth={h===60?1.5:0.5}
              strokeDasharray={h===60?"3,2":"none"}/>
            <text x={palletX-8} y={y+3} textAnchor="end" fontSize="7"
              fill={h===60?B.red:B.textLight} fontWeight={h===60?"700":"400"}>{h}"</text>
          </g>;
        })}
        <rect x={palletX} y={deckY} width={palletW} height={deckH} fill="#8B6914" rx="1"/>
        <text x={palletX+palletW/2} y={deckY+deckH/2+2.5} textAnchor="middle" fontSize="6" fill="white">PALLET</text>
        {pallet.layers.map((layer,i)=>{
          const layerH=p.caseH*scaleY;
          const y=deckY-layer.layer*layerH;
          const color=COLORS[i%COLORS.length];
          const w=layer.isPartial?palletW*(layer.cases/p.ti):palletW;
          return <g key={i}>
            <rect x={palletX} y={y} width={w} height={layerH-0.5} fill={color} rx="1" opacity={layer.isPartial?0.55:1}/>
            {!layer.isPartial&&<text x={palletX+palletW/2} y={y+layerH/2+2.5} textAnchor="middle" fontSize="6.5" fill="white" fontWeight="600">L{layer.layer}: {layer.cases}</text>}
          </g>;
        })}
        <line x1={palletX-10} y1={svgH-18} x2={palletX+palletW+10} y2={svgH-18} stroke={B.borderDark} strokeWidth="1.5"/>
      </svg>
      <div style={{fontSize:9,color:B.textLight,textAlign:"center"}}>
        <span style={{color:B.red,fontWeight:700}}>── 60" max</span> · 48"×40" pallet
      </div>
    </div>
  );
}

function PalletPlanner() {
  const [lines, setLines] = useState([{id:uid(),skuId:"",cases:""}]);
  const [savedPlans, setSavedPlans] = useStorage("palletPlans", []);
  const [planName, setPlanName] = useState("");
  const [activeViz, setActiveViz] = useState(0);
  const [toast, setToast] = useState(null);
  const [confirmDelete, setConfirmDelete] = useState(null);
  const toast_ = msg => setToast(msg);

  const results = useMemo(()=>
    lines.filter(l=>l.skuId&&parseInt(l.cases)>0)
      .map(l=>buildPlan(l.skuId,parseInt(l.cases))).filter(Boolean),
    [lines]);

  const totals = useMemo(()=>{
    const tp=results.reduce((s,r)=>s+r.totalPallets,0);
    const tw=results.reduce((s,r)=>s+r.pallets.reduce((ss,p)=>ss+p.totalWeight,0),0);
    const tc=results.reduce((s,r)=>s+r.totalCases,0);
    return {tp,tw,tc,isLTL:tp<=12};
  },[results]);

  const update=(i,f,v)=>{const n=[...lines];n[i]={...n[i],[f]:v};setLines(n);};

  const savePlan=()=>{
    if(!planName.trim()){toast_("Enter a plan name first");return;}
    if(results.length===0){toast_("Add SKUs first");return;}
    setSavedPlans(prev=>[...prev,{
      id:uid(),name:planName.trim(),lines:[...lines],
      totalPallets:totals.tp,totalCases:totals.tc,
      createdAt:new Date().toLocaleDateString(),
    }]);
    setPlanName("");
    toast_(`Plan "${planName}" saved`);
  };

  const loadPlan=(plan)=>{
    setLines(plan.lines.map(l=>({...l,id:uid()})));
    toast_(`Loaded: ${plan.name}`);
  };

  const deletePlan=(id)=>{
    setSavedPlans(prev=>prev.filter(p=>p.id!==id));
    setConfirmDelete(null);
    toast_("Plan deleted");
  };

  const vizResult = results[activeViz] || results[0];

  return (
    <div style={{display:"flex",flexDirection:"column",gap:20}}>
      {/* Entry panel */}
      <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{background:B.navy,padding:"14px 20px",display:"flex",
          justifyContent:"space-between",alignItems:"center"}}>
          <span style={{fontSize:14,fontWeight:700,color:B.white}}>
            📐 Build Plan — Enter SKUs & Cases
          </span>
          <button onClick={()=>setLines([...lines,{id:uid(),skuId:"",cases:""}])}
            style={{background:B.gold,border:"none",borderRadius:6,padding:"6px 14px",
              fontSize:12,fontWeight:700,color:B.navyDark,cursor:"pointer"}}>
            + Add SKU
          </button>
        </div>
        <div style={{padding:20,display:"flex",flexDirection:"column",gap:10}}>
          <div style={{display:"grid",gridTemplateColumns:"1fr 90px 80px 80px 32px",gap:8,
            fontSize:10,fontWeight:700,color:B.textLight,textTransform:"uppercase",
            letterSpacing:"0.5px",padding:"0 4px"}}>
            <span>SKU / Product</span><span>Cases</span>
            <span style={{textAlign:"center"}}>Cs/Plt</span>
            <span style={{textAlign:"center"}}>Pallets</span><span/>
          </div>
          {lines.map((line,i)=>{
            const p=PM[line.skuId];
            const cases=parseInt(line.cases)||0;
            const pallets=p&&cases?Math.ceil(cases/p.casesPerPallet):null;
            return (
              <div key={line.id} style={{display:"grid",
                gridTemplateColumns:"1fr 90px 80px 80px 32px",gap:8,alignItems:"center"}}>
                <select value={line.skuId} onChange={e=>update(i,"skuId",e.target.value)}
                  style={{background:B.cream,border:`1.5px solid ${B.border}`,borderRadius:8,
                    padding:"9px 10px",fontSize:12,color:B.text,outline:"none",cursor:"pointer",
                    fontFamily:"inherit"}}>
                  <option value="">— Select SKU —</option>
                  {PRODUCTS.map(p=>(
                    <option key={p.id} value={p.id}>{p.id} — {p.description} ({p.size})</option>
                  ))}
                </select>
                <input type="number" min="1" placeholder="0" value={line.cases}
                  onChange={e=>update(i,"cases",e.target.value)}
                  style={{background:B.cream,border:`1.5px solid ${B.border}`,borderRadius:8,
                    padding:"9px 10px",fontSize:13,color:B.text,outline:"none",
                    width:"100%",fontFamily:"inherit"}}/>
                <div style={{textAlign:"center",fontSize:11,color:B.textLight,
                  background:B.cream,borderRadius:8,padding:"9px 6px"}}>
                  {p?p.casesPerPallet:"—"}
                </div>
                <div style={{background:pallets?B.navyFaint:B.cream,borderRadius:8,
                  padding:"9px 10px",textAlign:"center",fontSize:14,
                  fontWeight:800,color:pallets?B.navy:B.textLight,border:`1.5px solid ${pallets?B.navy+"30":B.border}`}}>
                  {pallets||"—"}
                </div>
                <button onClick={()=>setLines(lines.filter((_,j)=>j!==i))}
                  style={{background:"none",border:`1px solid ${B.border}`,borderRadius:6,
                    color:B.red,cursor:"pointer",padding:"6px 8px",fontSize:13,lineHeight:1}}>✕</button>
              </div>
            );
          })}
        </div>

        {/* Totals */}
        {results.length>0&&(
          <div style={{background:B.navy,padding:"14px 24px",
            display:"flex",gap:28,alignItems:"center",flexWrap:"wrap"}}>
            {[
              ["Total Cases",totals.tc.toLocaleString()],
              ["Total Pallets",totals.tp],
              ["Est. Weight",`${totals.tw.toLocaleString()} lbs`],
              ["Load Type",totals.isLTL?"LTL":"FTL — Full Truck"],
            ].map(([label,val])=>(
              <div key={label}>
                <div style={{fontSize:10,color:"rgba(255,255,255,0.45)",fontWeight:600,
                  textTransform:"uppercase",letterSpacing:"0.5px",marginBottom:2}}>{label}</div>
                <div style={{fontSize:20,fontWeight:900,
                  color:label==="Load Type"?(totals.isLTL?B.goldLight:"#86EFAC"):B.white}}>
                  {val}
                </div>
              </div>
            ))}
            {/* Save plan */}
            <div style={{marginLeft:"auto",display:"flex",gap:8,alignItems:"center"}}>
              <input value={planName} onChange={e=>setPlanName(e.target.value)}
                placeholder="Plan name…"
                onKeyDown={e=>e.key==="Enter"&&savePlan()}
                style={{background:"rgba(255,255,255,0.1)",border:"1px solid rgba(255,255,255,0.2)",
                  borderRadius:6,padding:"7px 12px",fontSize:12,color:B.white,outline:"none",
                  fontFamily:"inherit",width:150}}/>
              <button onClick={savePlan}
                style={{background:B.gold,border:"none",borderRadius:6,
                  padding:"7px 14px",fontSize:12,fontWeight:700,color:B.navyDark,cursor:"pointer"}}>
                Save Plan
              </button>
            </div>
          </div>
        )}
      </div>

      {/* Saved plans */}
      {savedPlans.length>0&&(
        <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{background:B.sand,padding:"12px 18px",borderBottom:`1px solid ${B.border}`,
            display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:13,fontWeight:700,color:B.navy}}>
              💾 Saved Build Plans ({savedPlans.length})
            </span>
          </div>
          <div style={{padding:16,display:"flex",flexWrap:"wrap",gap:10}}>
            {savedPlans.map(plan=>(
              <div key={plan.id} style={{background:B.cream,border:`1px solid ${B.border}`,
                borderRadius:10,padding:"12px 14px",minWidth:180}}>
                <div style={{fontWeight:700,color:B.navy,fontSize:13,marginBottom:2}}>
                  {plan.name}
                </div>
                <div style={{fontSize:11,color:B.textLight,marginBottom:8}}>
                  {plan.totalCases} cs · {plan.totalPallets} pallets · {plan.createdAt}
                </div>
                <div style={{display:"flex",gap:6}}>
                  <button onClick={()=>loadPlan(plan)}
                    style={{background:B.navy,color:B.white,border:"none",borderRadius:6,
                      padding:"5px 10px",fontSize:11,fontWeight:700,cursor:"pointer"}}>
                    Load
                  </button>
                  <button onClick={()=>setConfirmDelete({id:plan.id,label:plan.name})}
                    style={{background:"none",border:`1px solid ${B.border}`,borderRadius:6,
                      padding:"5px 8px",fontSize:11,color:B.red,cursor:"pointer"}}>
                    ✕
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Per-SKU build detail */}
      {results.length>0&&(
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
          {results.map((r,ri)=>(
            <div key={ri} style={{background:B.white,border:`1px solid ${B.border}`,
              borderRadius:12,overflow:"hidden"}}>
              <div style={{background:ri===activeViz?B.navy:B.sand,padding:"12px 16px",
                cursor:"pointer",display:"flex",justifyContent:"space-between",
                alignItems:"center",transition:"background 0.15s"}}
                onClick={()=>setActiveViz(ri)}>
                <div>
                  <div style={{fontSize:11,fontWeight:800,color:ri===activeViz?B.gold:B.textMid}}>
                    {r.product.id}
                  </div>
                  <div style={{fontSize:13,fontWeight:700,color:ri===activeViz?B.white:B.text,marginTop:1}}>
                    {r.product.description}
                  </div>
                  <div style={{fontSize:11,color:ri===activeViz?"rgba(255,255,255,0.5)":B.textLight,marginTop:2}}>
                    {r.totalCases} cases · TiHi {r.product.tihi}
                  </div>
                </div>
                <div style={{textAlign:"right"}}>
                  <div style={{fontSize:28,fontWeight:900,color:ri===activeViz?B.white:B.navy}}>
                    {r.totalPallets}
                  </div>
                  <div style={{fontSize:10,color:ri===activeViz?"rgba(255,255,255,0.5)":B.textLight}}>
                    pallets
                  </div>
                </div>
              </div>
              <div style={{padding:14,display:"flex",flexDirection:"column",gap:10}}>
                {/* Pallet pills */}
                <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                  {r.pallets.map((plt,pi)=>(
                    <div key={pi} style={{background:plt.full?B.navyFaint:B.goldFaint,
                      border:`1px solid ${plt.full?B.navy+"30":B.gold+"60"}`,
                      borderRadius:7,padding:"6px 10px",fontSize:11}}>
                      <div style={{fontWeight:700,color:B.navy}}>
                        Pallet {plt.palletNum}{!plt.full&&" ⚠ partial"}
                      </div>
                      <div style={{color:B.textMid,marginTop:1}}>
                        {plt.cases} cs · {plt.totalWeight} lbs · {plt.totalHeight}"
                      </div>
                    </div>
                  ))}
                </div>
                {/* Layer table */}
                <div style={{background:B.cream,borderRadius:8,overflow:"hidden",
                  border:`1px solid ${B.border}`}}>
                  <div style={{padding:"7px 12px",background:B.sand,fontSize:9,fontWeight:700,
                    color:B.textMid,textTransform:"uppercase",letterSpacing:"0.5px",
                    display:"grid",gridTemplateColumns:"28px 1fr 60px 60px 60px"}}>
                    <span>Lyr</span><span>Fill</span>
                    <span style={{textAlign:"right"}}>Cases</span>
                    <span style={{textAlign:"right"}}>Total</span>
                    <span style={{textAlign:"right"}}>Ht"</span>
                  </div>
                  {r.pallets[0]?.layers.map((layer,li)=>(
                    <div key={li} style={{padding:"6px 12px",
                      background:li%2===0?B.white:B.cream,
                      display:"grid",gridTemplateColumns:"28px 1fr 60px 60px 60px",
                      alignItems:"center",fontSize:11,
                      borderTop:`1px solid ${B.border}`}}>
                      <span style={{fontWeight:800,color:B.navy,fontSize:10}}>L{layer.layer}</span>
                      <div style={{display:"flex",alignItems:"center",gap:5}}>
                        <div style={{height:7,background:B.navy,borderRadius:2,opacity:layer.isPartial?0.35:1,
                          width:Math.max(16,(layer.cases/r.product.ti)*50)}}/>
                        {layer.isPartial&&<span style={{fontSize:9,color:B.amber,fontWeight:700}}>partial</span>}
                      </div>
                      <span style={{textAlign:"right",fontWeight:700,color:B.text}}>{layer.cases}</span>
                      <span style={{textAlign:"right",color:B.textMid}}>{layer.cumulativeCases}</span>
                      <span style={{textAlign:"right",fontWeight:700,fontSize:11,
                        color:layer.heightAtTop>58?B.red:layer.heightAtTop>50?B.amber:B.green}}>
                        {layer.heightAtTop}"
                      </span>
                    </div>
                  ))}
                  <div style={{padding:"7px 12px",background:B.navy,
                    display:"grid",gridTemplateColumns:"28px 1fr 60px 60px 60px",
                    fontSize:10,fontWeight:700,color:B.white}}>
                    <span>↑</span>
                    <span style={{color:B.gold}}>{r.product.tihi}</span>
                    <span style={{textAlign:"right"}}>{r.pallets[0]?.cases}</span>
                    <span style={{textAlign:"right"}}>{r.pallets[0]?.totalWeight} lbs</span>
                    <span style={{textAlign:"right",
                      color:r.pallets[0]?.totalHeight>60?B.red:B.goldLight}}>
                      {r.pallets[0]?.totalHeight}"
                    </span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Visualizer */}
      {vizResult&&(
        <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,
          padding:20,display:"flex",gap:24,alignItems:"flex-start"}}>
          <PalletVisualizer plan={vizResult}/>
          <div style={{flex:1}}>
            <div style={{fontSize:13,fontWeight:700,color:B.navy,marginBottom:3}}>
              {vizResult.product.id} — {vizResult.product.description}
            </div>
            <div style={{fontSize:12,color:B.textMid,marginBottom:16}}>
              Profile view · Pallet 1 of {vizResult.totalPallets}
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
              {[
                ["Case Dimensions",`${vizResult.product.caseL}" × ${vizResult.product.caseW}" × ${vizResult.product.caseH}"H`],
                ["TiHi",vizResult.product.tihi],
                ["Cases / Layer (Ti)",vizResult.product.ti],
                ["Layers / Pallet (Hi)",vizResult.product.hi],
                ["Cases / Full Pallet",vizResult.product.casesPerPallet],
                ["Case Weight",`${vizResult.product.caseWeight} lbs`],
                ["Full Pallet Weight",`${vizResult.product.palletWeight.toLocaleString()} lbs`],
                ["Stack Height",`${vizResult.product.stackHeight}"`],
              ].map(([label,val])=>(
                <div key={label} style={{background:B.cream,border:`1px solid ${B.border}`,
                  borderRadius:7,padding:"9px 12px"}}>
                  <div style={{fontSize:9,fontWeight:700,color:B.textLight,
                    textTransform:"uppercase",letterSpacing:"0.5px",marginBottom:3}}>{label}</div>
                  <div style={{fontSize:13,fontWeight:700,color:B.navy}}>{val}</div>
                </div>
              ))}
            </div>
            <button onClick={()=>window.print()}
              style={{marginTop:14,background:B.navy,color:B.white,border:"none",
                borderRadius:8,padding:"10px 18px",fontSize:12,fontWeight:700,
                cursor:"pointer",display:"flex",alignItems:"center",gap:6}}>
              🖨 Print Build Sheet
            </button>
          </div>
        </div>
      )}

      {/* SKU reference table — click to add */}
      <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{background:B.sand,padding:"11px 18px",borderBottom:`1px solid ${B.border}`}}>
          <span style={{fontSize:13,fontWeight:700,color:B.navy}}>
            SKU Reference — Click any row to add to plan
          </span>
        </div>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
            <thead>
              <tr style={{background:B.cream}}>
                {["SKU","Description","Size","TiHi","Cs/Pallet","Case Wt","Pallet Wt","Stack Ht"].map(h=>(
                  <th key={h} style={{padding:"8px 12px",textAlign:"left",fontSize:9,fontWeight:700,
                    color:B.textLight,textTransform:"uppercase",letterSpacing:"0.5px",
                    borderBottom:`1px solid ${B.border}`,whiteSpace:"nowrap"}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {PRODUCTS.map((p,i)=>(
                <tr key={p.id}
                  style={{background:i%2===0?B.white:B.cream,cursor:"pointer",
                    transition:"background 0.1s"}}
                  onMouseEnter={e=>e.currentTarget.style.background=B.sand}
                  onMouseLeave={e=>e.currentTarget.style.background=i%2===0?B.white:B.cream}
                  onClick={()=>{
                    if(!lines.find(l=>l.skuId===p.id))
                      setLines(prev=>[...prev,{id:uid(),skuId:p.id,cases:""}]);
                    toast_(`${p.id} added to plan`);
                  }}>
                  <td style={{padding:"8px 12px",fontWeight:800,color:B.navy}}>{p.id}</td>
                  <td style={{padding:"8px 12px",color:B.text}}>{p.description}</td>
                  <td style={{padding:"8px 12px",color:B.textMid,whiteSpace:"nowrap"}}>{p.size}</td>
                  <td style={{padding:"8px 12px",fontWeight:700,color:B.navy,textAlign:"center"}}>{p.tihi}</td>
                  <td style={{padding:"8px 12px",fontWeight:700,color:B.green,textAlign:"center"}}>{p.casesPerPallet}</td>
                  <td style={{padding:"8px 12px",color:B.textMid,textAlign:"right"}}>{p.caseWeight} lbs</td>
                  <td style={{padding:"8px 12px",textAlign:"right",
                    color:p.palletWeight>2200?B.red:B.textMid,
                    fontWeight:p.palletWeight>2200?700:400}}>
                    {p.palletWeight.toLocaleString()}
                  </td>
                  <td style={{padding:"8px 12px",textAlign:"right",fontWeight:700,
                    color:p.stackHeight>58?B.red:p.stackHeight>54?B.amber:B.green}}>
                    {p.stackHeight}"
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {confirmDelete?.label&&(
        <Confirm
          message={`Delete plan "${confirmDelete.label}"?`}
          onConfirm={()=>deletePlan(confirmDelete.id)}
          onCancel={()=>setConfirmDelete(null)}/>
      )}
      {toast&&<Toast message={toast} onDone={()=>setToast(null)}/>}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  DASHBOARD
// ─────────────────────────────────────────────────────────────
function Dashboard() {
  const [shipments] = useStorage("shipments", SEED_SHIPMENTS);
  const [inventory] = useStorage("inventory", SEED_INVENTORY);

  const ready    = shipments.filter(s=>s.status==="Ready to Ship").length;
  const inbound  = shipments.filter(s=>["From RJW","From Boves","From PCC","Inbound Transfer"].includes(s.status)).length;
  const noCarrier= shipments.filter(s=>!s.carrier&&!["PO Shipped","Cancelled"].includes(s.status)).length;
  const lowStock = inventory.flatMap(l=>l.items.filter(i=>i.onHand<50));
  const today    = shipments.filter(s=>s.shipDate==="2026-02-27");
  const urgentMABDs = shipments.filter(s=>{
    const m=extractMABD(s.notes);
    if(!m) return false;
    const d=new Date(m), ref=new Date("2026-02-27");
    const diff=(d-ref)/86400000;
    return diff>=0&&diff<=7;
  });

  return (
    <div style={{display:"flex",flexDirection:"column",gap:20}}>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:14}}>
        {[
          ["Ready to Ship",    ready,             "outbound orders",    B.green],
          ["MABDs ≤ 7 Days",   urgentMABDs.length,"need immediate action",B.red],
          ["Inbound / Transfer",inbound,          "in transit to you",  B.blue],
          ["No Carrier Assigned",noCarrier,       "need quote",         B.amber],
        ].map(([label,val,sub,accent])=>(
          <div key={label} style={{background:B.white,border:`1px solid ${B.border}`,
            borderLeft:`4px solid ${accent}`,borderRadius:12,padding:"18px 20px"}}>
            <div style={{fontSize:10,fontWeight:700,color:B.textLight,
              textTransform:"uppercase",letterSpacing:"0.5px",marginBottom:6}}>{label}</div>
            <div style={{fontSize:32,fontWeight:900,color:B.navy,lineHeight:1}}>{val}</div>
            <div style={{fontSize:11,color:B.textLight,marginTop:5}}>{sub}</div>
          </div>
        ))}
      </div>
      <div style={{background:B.goldFaint,border:`1px solid ${B.gold}40`,borderRadius:8,
        padding:"9px 16px",fontSize:12,color:B.textMid}}>
        💡 All numbers reflect your live edits — status changes in Truck Schedule update this dashboard instantly
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
        {/* Urgent MABDs */}
        <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{background:B.navy,padding:"12px 18px",display:"flex",
            justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:13,fontWeight:700,color:B.white}}>🚨 MABDs Due This Week</span>
            <span style={{background:B.red,color:B.white,padding:"2px 8px",
              borderRadius:4,fontSize:11,fontWeight:700}}>{urgentMABDs.length}</span>
          </div>
          {urgentMABDs.length===0&&(
            <div style={{padding:24,textAlign:"center",color:B.green,fontSize:13,fontWeight:600}}>
              ✓ No urgent MABDs this week
            </div>
          )}
          {urgentMABDs.slice(0,8).map((s,i)=>{
            const mabd=extractMABD(s.notes);
            const pallets=extractPallets(s.notes);
            const cc=customerColor(s.customer);
            return (
              <div key={i} style={{padding:"10px 18px",borderBottom:`1px solid ${B.border}`,
                display:"flex",justifyContent:"space-between",alignItems:"center",
                background:i%2===0?B.white:B.cream}}>
                <div>
                  <div style={{fontSize:12,fontWeight:700,color:B.navy}}>{s.po}</div>
                  <div style={{marginTop:3,display:"flex",alignItems:"center",gap:6}}>
                    <span style={{padding:"1px 6px",borderRadius:3,fontSize:10,
                      fontWeight:700,color:cc.color,background:cc.bg}}>{s.customer}</span>
                    <span style={{fontSize:10,color:B.textLight}}>{s.broker||"No broker"}</span>
                  </div>
                </div>
                <div style={{textAlign:"right"}}>
                  <div style={{fontWeight:800,color:B.red,fontSize:13}}>{mabd}</div>
                  {pallets&&<div style={{fontSize:10,color:B.textLight}}>{pallets} pallets</div>}
                </div>
              </div>
            );
          })}
        </div>
        {/* Low stock */}
        <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{background:B.navy,padding:"12px 18px",display:"flex",
            justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:13,fontWeight:700,color:B.white}}>⚠️ Low Inventory Alerts</span>
            <span style={{background:B.amber,color:B.white,padding:"2px 8px",
              borderRadius:4,fontSize:11,fontWeight:700}}>{lowStock.length} SKUs</span>
          </div>
          {lowStock.length===0&&(
            <div style={{padding:24,textAlign:"center",color:B.green,fontSize:13,fontWeight:600}}>
              ✓ All inventory levels healthy
            </div>
          )}
          {lowStock.map((item,i)=>{
            const loc=inventory.find(l=>l.items.includes(item));
            return (
              <div key={i} style={{padding:"10px 18px",borderBottom:`1px solid ${B.border}`,
                display:"flex",justifyContent:"space-between",alignItems:"center",
                background:"#FFF8F8"}}>
                <div>
                  <span style={{fontWeight:800,color:B.navy,fontSize:12,marginRight:7}}>{item.sku}</span>
                  <span style={{fontSize:12,color:B.text}}>{item.desc}</span>
                  <div style={{fontSize:10,color:B.textLight,marginTop:2}}>{loc?.location}</div>
                </div>
                <div style={{fontSize:20,fontWeight:900,color:B.red}}>{item.onHand}</div>
              </div>
            );
          })}
        </div>
      </div>
      {/* Today's shipments */}
      <div style={{background:B.white,border:`1px solid ${B.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{background:B.navy,padding:"12px 18px",display:"flex",
          justifyContent:"space-between",alignItems:"center"}}>
          <span style={{fontSize:13,fontWeight:700,color:B.white}}>
            📅 Today — February 27, 2026
          </span>
          <span style={{background:"rgba(255,255,255,0.15)",color:B.white,padding:"2px 10px",
            borderRadius:4,fontSize:11,fontWeight:700}}>{today.length} orders</span>
        </div>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
          <thead>
            <tr style={{background:B.sand}}>
              {["PO","Customer","Status","Broker","Carrier","MABD","Pallets"].map(h=>(
                <th key={h} style={{padding:"8px 14px",textAlign:"left",fontSize:10,
                  fontWeight:700,color:B.textLight,textTransform:"uppercase",
                  letterSpacing:"0.5px",borderBottom:`1px solid ${B.border}`}}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {today.map((s,i)=>{
              const st=stageOf(s.status);
              const mabd=extractMABD(s.notes);
              const pallets=extractPallets(s.notes);
              const cc=customerColor(s.customer);
              return (
                <tr key={s.id} style={{background:i%2===0?B.white:B.cream}}>
                  <td style={{padding:"10px 14px",fontWeight:700,color:B.navy}}>{s.po}</td>
                  <td style={{padding:"10px 14px"}}>
                    <span style={{padding:"2px 8px",borderRadius:4,fontSize:11,
                      fontWeight:700,color:cc.color,background:cc.bg}}>{s.customer}</span>
                  </td>
                  <td style={{padding:"10px 14px"}}>
                    <span style={{display:"inline-flex",alignItems:"center",gap:4,
                      padding:"2px 8px",borderRadius:4,fontSize:11,fontWeight:600,
                      color:st.color,background:st.bg}}>
                      <span style={{width:5,height:5,borderRadius:"50%",background:st.dot}}/>
                      {s.status}
                    </span>
                  </td>
                  <td style={{padding:"10px 14px",color:B.textMid,fontSize:11}}>{s.broker||"—"}</td>
                  <td style={{padding:"10px 14px",color:s.carrier?B.text:B.textLight,
                    fontStyle:s.carrier?"normal":"italic",fontSize:11}}>{s.carrier||"TBD"}</td>
                  <td style={{padding:"10px 14px",fontWeight:700,
                    color:mabd?B.red:B.border}}>{mabd||"—"}</td>
                  <td style={{padding:"10px 14px",textAlign:"center",
                    fontWeight:700,color:B.navy}}>{pallets||"—"}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  ROOT
// ─────────────────────────────────────────────────────────────
export default function App() {
  const [page,setPage]=useState("dashboard");
  const PAGES=[
    {id:"dashboard", label:"Dashboard"},
    {id:"schedule",  label:"Truck Schedule"},
    {id:"inventory", label:"Inventory"},
    {id:"planner",   label:"Pallet Planner"},
  ];

  return (
    <div style={{fontFamily:"'DM Sans','Segoe UI',sans-serif",background:B.cream,
      minHeight:"100vh",color:B.text,display:"flex",flexDirection:"column"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&display=swap');
        *{box-sizing:border-box;} body{margin:0;}
        ::-webkit-scrollbar{width:5px;height:5px;}
        ::-webkit-scrollbar-track{background:${B.cream};}
        ::-webkit-scrollbar-thumb{background:${B.borderDark};border-radius:3px;}
        select option{background:white;color:${B.text};}
        input::placeholder,textarea::placeholder{color:${B.textLight};}
        input:focus,select:focus,textarea:focus{border-color:${B.navy}!important;outline:none;}
        textarea{resize:vertical;}
        @keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
        @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
        @media print{nav,.no-print{display:none!important;}}
      `}</style>

      {/* Topbar */}
      <div style={{background:B.navy,borderBottom:`3px solid ${B.gold}`,
        padding:"0 28px",display:"flex",alignItems:"center",
        justifyContent:"space-between",height:58,flexShrink:0}}>
        <div style={{display:"flex",alignItems:"center",gap:14}}>
          <div style={{background:B.white,borderRadius:8,width:38,height:38,
            display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,padding:3}}>
            <div style={{fontSize:10,fontWeight:900,color:B.navy,textAlign:"center",lineHeight:1.1,
              fontStyle:"italic"}}>Yo<br/>Mama's</div>
          </div>
          <div>
            <div style={{fontSize:15,fontWeight:800,color:B.white,lineHeight:1,letterSpacing:"-0.3px"}}>
              Operations Hub
            </div>
            <div style={{fontSize:10,color:B.gold,fontWeight:600,letterSpacing:"1.5px",
              textTransform:"uppercase",marginTop:1}}>Yo Mama's Foods Co.</div>
          </div>
        </div>
        <nav style={{display:"flex",gap:2}}>
          {PAGES.map(p=>(
            <button key={p.id} onClick={()=>setPage(p.id)}
              style={{padding:"8px 16px",borderRadius:7,border:"none",cursor:"pointer",
                fontSize:13,fontWeight:600,background:page===p.id?"rgba(201,168,76,0.2)":"transparent",
                color:page===p.id?B.gold:"rgba(255,255,255,0.6)",
                borderBottom:page===p.id?`2px solid ${B.gold}`:"2px solid transparent",
                transition:"all 0.15s"}}>
              {p.label}
            </button>
          ))}
        </nav>
        <div style={{display:"flex",alignItems:"center",gap:12,fontSize:11,
          color:"rgba(255,255,255,0.5)"}}>
          <div style={{display:"flex",alignItems:"center",gap:5,
            background:"rgba(26,122,74,0.25)",border:"1px solid rgba(26,122,74,0.5)",
            borderRadius:16,padding:"3px 10px",color:"#6EE7B7",fontWeight:600}}>
            <span style={{width:6,height:6,borderRadius:"50%",background:"#34D399",
              animation:"pulse 2s infinite",display:"inline-block"}}/>
            Auto-save ON
          </div>
          <div style={{width:30,height:30,borderRadius:"50%",
            background:"rgba(201,168,76,0.2)",border:`1px solid ${B.gold}`,
            display:"flex",alignItems:"center",justifyContent:"center",
            fontSize:12,fontWeight:800,color:B.gold}}>N</div>
        </div>
      </div>

      {/* Content */}
      <div style={{flex:1,overflow:"auto",padding:24,display:"flex",flexDirection:"column",gap:20}}>
        <div>
          <h1 style={{margin:0,fontSize:22,fontWeight:900,color:B.navy,letterSpacing:"-0.3px"}}>
            {page==="dashboard"?"Operations Overview":page==="schedule"?"Truck Schedule":page==="inventory"?"Inventory — All Locations":"Pallet Build Planner"}
          </h1>
          <p style={{margin:"4px 0 0",fontSize:13,color:B.textLight}}>
            {page==="dashboard"&&"February 27, 2026 · Updates live as you edit"}
            {page==="schedule"&&"Click any cell to edit inline · Status badge opens dropdown · All changes auto-saved"}
            {page==="inventory"&&"Click quantities to edit · Add or remove SKU rows · Changes auto-saved"}
            {page==="planner"&&`48"×40"×60" max · Layer-by-layer build instructions · Save and reload plans`}
          </p>
        </div>
        {page==="dashboard" &&<Dashboard/>}
        {page==="schedule"  &&<TruckSchedule/>}
        {page==="inventory" &&<InventoryView/>}
        {page==="planner"   &&<PalletPlanner/>}
      </div>
    </div>
  );
}
