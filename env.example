const stageOf = s => STAGE_META[s] || {color:B.textMid,bg:B.sand,dot:B.textLight};

const customerColor = name => {
  if (!name) return {bg:B.sand,color:B.textMid};
  if (name.includes("KEHE"))   return {bg:"#EBF4FF",color:B.blue};
  if (name.includes("UNFI"))   return {bg:"#F0FFF4",color:B.green};
  if (name.includes("COSTCO")) return {bg:"#FFF0F0",color:B.red};
  if (name.includes("Amazon")) return {bg:"#FFFBEB",color:B.amber};
  if (name.includes("Kroger")) return {bg:"#F5F0FF",color:"#6B21A8"};
  return {bg:B.sand,color:B.textMid};
};

const extractMABD = notes => {
  const m = notes?.match(/MABD\s+(\d{1,2}\/\d{1,2}\/\d{4})/i);
  return m ? m[1] : null;
};
const extractPallets = notes => {
  const m = notes?.match(/(\d+)\s*[Pp]allet/);
  return m ? parseInt(m[1]) : null;
};
const uid = () => Math.random().toString(36).slice(2,10);

